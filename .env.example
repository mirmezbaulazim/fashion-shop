# MongoDB Atlas connection string (Free cluster)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/fashion-shop

# Admin login (used to create the first admin account via seed script)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123

# JWT secret for admin session tokens (any long random string)
JWT_SECRET=replace_this_with_a_long_random_string

# Cloudinary (free tier) - for product image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SSLCommerz (Sandbox first, then Live keys)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false

# Your site URL (used for payment redirect callbacks)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
